<svg xmlns="http://www.w3.org/2000/svg" width="{{ width }}" height="{{ height }}" viewBox="0 0 {{ width }} {{ height }}">
  <defs>
    <style>
      .title { font: 600 14px system-ui, -apple-system, sans-serif; fill: {{ theme.accent }}; }
      .subtitle { font: 400 11px system-ui, -apple-system, sans-serif; fill: {{ theme.text_secondary }}; }
      .icon-label { font: 500 10px system-ui, -apple-system, sans-serif; fill: {{ theme.text_primary }}; }
      .icon-count { font: 600 9px system-ui, -apple-system, sans-serif; }
    </style>
  </defs>

  <rect width="100%" height="100%" fill="{{ theme.background }}" rx="8"{% if not hide_border %} stroke="{{ theme.border }}" stroke-width="1"{% endif %}/>

  <!-- Header -->
  <text x="{{ style.padding }}" y="{{ style.padding + 12 }}" class="title">@{{ username }}'s Stack</text>
  <text x="{{ style.padding }}" y="{{ style.padding + 26 }}" class="subtitle">{{ technologies|length }} technologies</text>

  <!-- Separator line -->
  <line x1="{{ style.padding }}" y1="{{ style.padding + 33 }}" x2="{{ width - style.padding }}" y2="{{ style.padding + 33 }}" stroke="{{ theme.border }}" stroke-width="1"/>

  <!-- Grid items -->
  {% for tech in technologies %}
  {% set col = loop.index0 % style.columns %}
  {% set row = loop.index0 // style.columns %}
  {% set x = style.padding + col * (style.item_width + style.gap) %}
  {% set y = style.padding + 42 + row * (style.item_height + style.gap) %}

  <g transform="translate({{ x }}, {{ y }})">
    {% set icon_data = get_icon_data_uri(tech.icon) %}
    <!-- Icon -->
    {% if icon_data %}
    <image x="{{ style.item_width // 2 - 16 }}" y="2" width="32" height="32" href="{{ icon_data }}"/>
    {% else %}
    <circle cx="{{ style.item_width // 2 }}" cy="18" r="18" fill="{{ tech.color }}"/>
    <text x="{{ style.item_width // 2 }}" y="23" text-anchor="middle" fill="white" font-size="14" font-weight="bold">{{ tech.name[0] }}</text>
    {% endif %}

    <!-- Label -->
    <text x="{{ style.item_width // 2 }}" y="50" text-anchor="middle" class="icon-label">{{ tech.name[:14] }}{% if tech.name|length > 14 %}..{% endif %}</text>

    <!-- Count indicator -->
    <text x="{{ style.item_width // 2 }}" y="62" text-anchor="middle" class="icon-count" fill="{{ tech.color }}">{{ tech.count }} repo{{ 's' if tech.count != 1 else '' }}</text>
  </g>
  {% endfor %}
</svg>
