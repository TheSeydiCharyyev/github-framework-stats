<svg xmlns="http://www.w3.org/2000/svg" width="{{ width }}" height="{{ height }}" viewBox="0 0 {{ width }} {{ height }}">
  <defs>
    <style>
      .title { font: 600 14px system-ui, -apple-system, sans-serif; fill: {{ theme.text_primary }}; }
      .stat-label { font: 400 12px system-ui, -apple-system, sans-serif; fill: {{ theme.text_secondary }}; }
      .stat-value { font: 700 12px system-ui, -apple-system, sans-serif; fill: {{ theme.text_primary }}; }
      .cat-name { font: 400 11px system-ui, -apple-system, sans-serif; fill: {{ theme.text_primary }}; }
      .cat-pct { font: 400 11px system-ui, -apple-system, sans-serif; fill: {{ theme.text_secondary }}; }
    </style>
  </defs>

  <rect width="100%" height="100%" fill="{{ theme.background }}" rx="6" stroke="{{ theme.border }}" stroke-width="1"/>

  <!-- Title -->
  <text x="25" y="35" class="title">Tech Stack Stats</text>

  {% set bar_width = width - 50 %}

  <!-- Summary stats -->
  <g transform="translate(25, 60)">
    <text x="0" y="0" class="stat-label">Total Technologies</text>
    <text x="{{ bar_width }}" y="0" text-anchor="end" class="stat-value">{{ total_techs }}</text>
  </g>
  <g transform="translate(25, 82)">
    <text x="0" y="0" class="stat-label">Repos Analyzed</text>
    <text x="{{ bar_width }}" y="0" text-anchor="end" class="stat-value">{{ total_repos }}</text>
  </g>

  <!-- Separator -->
  <line x1="25" y1="100" x2="{{ width - 25 }}" y2="100" stroke="{{ theme.border }}" stroke-width="1" opacity="0.5"/>

  <!-- Category breakdown -->
  {% set max_cat_pct = categories[0].pct if categories else 0 %}
  {% for cat in categories %}
  {% set y = 120 + loop.index0 * 36 %}
  <g transform="translate(25, {{ y }})">
    <text x="0" y="0" class="cat-name">{{ cat.label }}</text>
    <text x="{{ bar_width }}" y="0" text-anchor="end" class="cat-pct">{{ cat.count }} · {{ "%.0f"|format(cat.pct) }}%</text>
    <rect x="0" y="8" width="{{ bar_width }}" height="8" rx="4" fill="{{ theme.border }}" opacity="0.4"/>
    <rect x="0" y="8" width="{{ (cat.pct / max_cat_pct * bar_width) if max_cat_pct > 0 else 0 }}" height="8" rx="4" fill="{{ cat.color }}"/>
  </g>
  {% endfor %}
</svg>
