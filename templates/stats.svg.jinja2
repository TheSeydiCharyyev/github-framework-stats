<svg xmlns="http://www.w3.org/2000/svg" width="{{ width }}" height="{{ height }}" viewBox="0 0 {{ width }} {{ height }}">
  <defs>
    <style>
      .title { font: 700 18px system-ui, -apple-system, sans-serif; fill: {{ theme.text_primary }}; }
      .cat-label { font: 400 14px system-ui, -apple-system, sans-serif; fill: {{ theme.text_secondary }}; }
      .cat-value { font: 700 14px system-ui, -apple-system, sans-serif; fill: {{ theme.text_primary }}; }
      .sep-label { font: 600 14px system-ui, -apple-system, sans-serif; fill: {{ theme.text_primary }}; }
      .sep-value { font: 700 14px system-ui, -apple-system, sans-serif; fill: {{ theme.accent }}; }
    </style>

    <!-- Category icons -->
    <symbol id="icon-languages" viewBox="0 0 14 14">
      <path d="M5 1.5L1.5 7L5 12.5" stroke="currentColor" fill="none" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
      <path d="M9 1.5L12.5 7L9 12.5" stroke="currentColor" fill="none" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
    </symbol>

    <symbol id="icon-frameworks" viewBox="0 0 14 14">
      <rect x="0.5" y="0.5" width="5.5" height="5.5" rx="1.2" fill="currentColor"/>
      <rect x="8" y="0.5" width="5.5" height="5.5" rx="1.2" fill="currentColor" opacity="0.6"/>
      <rect x="0.5" y="8" width="5.5" height="5.5" rx="1.2" fill="currentColor" opacity="0.6"/>
      <rect x="8" y="8" width="5.5" height="5.5" rx="1.2" fill="currentColor" opacity="0.35"/>
    </symbol>

    <symbol id="icon-http-api" viewBox="0 0 14 14">
      <circle cx="7" cy="7" r="5.8" stroke="currentColor" fill="none" stroke-width="1.4"/>
      <ellipse cx="7" cy="7" rx="2.8" ry="5.8" stroke="currentColor" fill="none" stroke-width="1.4"/>
      <line x1="1" y1="7" x2="13" y2="7" stroke="currentColor" stroke-width="1.4"/>
    </symbol>

    <symbol id="icon-build" viewBox="0 0 14 14">
      <path d="M8.5 2L12 5.5M1.5 12.5l7-7M1.5 12.5l2.5 0 0-2.5" stroke="currentColor" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      <path d="M10 1l3 3-1.5 1.5-3-3z" fill="currentColor" opacity="0.4"/>
    </symbol>

    <symbol id="icon-state" viewBox="0 0 14 14">
      <ellipse cx="7" cy="3" rx="6" ry="2.5" fill="currentColor" opacity="0.3"/>
      <ellipse cx="7" cy="7" rx="6" ry="2.5" fill="currentColor" opacity="0.6"/>
      <ellipse cx="7" cy="11" rx="6" ry="2.5" fill="currentColor"/>
    </symbol>

    <symbol id="icon-ui-styling" viewBox="0 0 14 14">
      <circle cx="4" cy="4" r="3.5" stroke="currentColor" fill="none" stroke-width="1.4"/>
      <circle cx="10" cy="4" r="3.5" stroke="currentColor" fill="none" stroke-width="1.4"/>
      <circle cx="7" cy="9.5" r="3.5" stroke="currentColor" fill="none" stroke-width="1.4"/>
    </symbol>

    <symbol id="icon-devops" viewBox="0 0 14 14">
      <circle cx="7" cy="7" r="5.5" stroke="currentColor" fill="none" stroke-width="1.4"/>
      <circle cx="7" cy="7" r="2" fill="currentColor"/>
      <line x1="7" y1="1.2" x2="7" y2="3.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
      <line x1="7" y1="10.5" x2="7" y2="12.8" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
      <line x1="1.2" y1="7" x2="3.5" y2="7" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
      <line x1="10.5" y1="7" x2="12.8" y2="7" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
    </symbol>

    <symbol id="icon-backend" viewBox="0 0 14 14">
      <rect x="1" y="1" width="12" height="5" rx="1.5" stroke="currentColor" fill="none" stroke-width="1.4"/>
      <rect x="1" y="8" width="12" height="5" rx="1.5" stroke="currentColor" fill="none" stroke-width="1.4"/>
      <circle cx="4" cy="3.5" r="1" fill="currentColor"/>
      <circle cx="4" cy="10.5" r="1" fill="currentColor"/>
    </symbol>

    <symbol id="icon-testing" viewBox="0 0 14 14">
      <circle cx="7" cy="7" r="6" stroke="currentColor" fill="none" stroke-width="1.4"/>
      <path d="M4 7l2 2.5L10 5" stroke="currentColor" fill="none" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
    </symbol>

    <symbol id="icon-database" viewBox="0 0 14 14">
      <ellipse cx="7" cy="3" rx="5.5" ry="2.3" stroke="currentColor" fill="none" stroke-width="1.4"/>
      <path d="M1.5 3v8c0 1.3 2.5 2.3 5.5 2.3s5.5-1 5.5-2.3V3" stroke="currentColor" fill="none" stroke-width="1.4"/>
      <path d="M1.5 7c0 1.3 2.5 2.3 5.5 2.3s5.5-1 5.5-2.3" stroke="currentColor" fill="none" stroke-width="1.4"/>
    </symbol>

    <symbol id="icon-hosting" viewBox="0 0 14 14">
      <path d="M3.5 12.5h7" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
      <path d="M2 11.5a3.5 3.5 0 01-.5-1.8 3 3 0 012.8-3 4.5 4.5 0 018.7 1 2.8 2.8 0 01-1 5.3H2.5" stroke="currentColor" fill="none" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
    </symbol>

    <symbol id="icon-ml" viewBox="0 0 14 14">
      <circle cx="7" cy="5" r="3" stroke="currentColor" fill="none" stroke-width="1.4"/>
      <path d="M7 2v-1M4.5 3.5L3.5 2.5M9.5 3.5l1-1M4.5 6.5L3.5 7.5M9.5 6.5l1 1" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
      <path d="M7 8v2.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
      <path d="M4 13h6" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
      <path d="M5 10.5h4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
    </symbol>

    <symbol id="icon-other" viewBox="0 0 14 14">
      <circle cx="3" cy="7" r="1.5" fill="currentColor"/>
      <circle cx="7" cy="7" r="1.5" fill="currentColor"/>
      <circle cx="11" cy="7" r="1.5" fill="currentColor"/>
    </symbol>
  </defs>

  <rect width="100%" height="100%" fill="{{ theme.background }}" rx="8" stroke="{{ theme.border }}" stroke-width="1"/>

  <!-- Title -->
  <text x="{{ padding + 6 }}" y="{{ padding + 22 }}" class="title">Tech Stack Stats</text>

  {% set content_x = padding + 6 %}
  {% set value_x = width - padding - 6 %}
  {% set start_y = padding + header_height %}

  <!-- Category rows -->
  {% for cat in categories %}
  {% set y = start_y + loop.index0 * row_height %}
  <g transform="translate({{ content_x }}, {{ y }})">
    <use href="#icon-{{ cat.icon_id }}" x="-2" y="-13" width="16" height="16" color="{{ cat.color }}"/>
    <text x="20" y="0" class="cat-label">{{ cat.label }}</text>
    <text x="{{ value_x - content_x }}" y="0" text-anchor="end" class="cat-value">{{ cat.count }}</text>
  </g>
  {% endfor %}

  <!-- Separator line -->
  {% set sep_y = start_y + categories|length * row_height + 10 %}
  <line x1="{{ content_x }}" y1="{{ sep_y }}" x2="{{ value_x }}" y2="{{ sep_y }}" stroke="{{ theme.border }}" stroke-width="1" opacity="0.4"/>

  <!-- Totals -->
  {% set total_y = sep_y + 28 %}
  <g transform="translate({{ content_x }}, {{ total_y }})">
    <text x="0" y="0" class="sep-label">Total Technologies</text>
    <text x="{{ value_x - content_x }}" y="0" text-anchor="end" class="sep-value">{{ total_techs }}</text>
  </g>
  <g transform="translate({{ content_x }}, {{ total_y + 28 }})">
    <text x="0" y="0" class="sep-label">Repos Analyzed</text>
    <text x="{{ value_x - content_x }}" y="0" text-anchor="end" class="sep-value">{{ total_repos }}</text>
  </g>
</svg>
