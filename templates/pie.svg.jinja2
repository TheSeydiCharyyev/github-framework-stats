<svg xmlns="http://www.w3.org/2000/svg" width="{{ width }}" height="{{ height }}" viewBox="0 0 {{ width }} {{ height }}">
  <defs>
    <style>
      .title { font: 600 14px system-ui, -apple-system, sans-serif; fill: {{ theme.accent }}; }
      .subtitle { font: 400 11px system-ui, -apple-system, sans-serif; fill: {{ theme.text_secondary }}; }
      .legend-text { font: 400 11px system-ui, -apple-system, sans-serif; fill: {{ theme.text_primary }}; }
      .legend-pct { font: 600 11px system-ui, -apple-system, sans-serif; fill: {{ theme.text_secondary }}; }
    </style>
  </defs>

  <rect width="100%" height="100%" fill="{{ theme.background }}" rx="6"{% if not hide_border %} stroke="{{ theme.border }}" stroke-width="1"{% endif %}/>

  <!-- Header -->
  <text x="{{ style.padding }}" y="28" class="title">@{{ username }}'s Tech Distribution</text>

  <!-- Separator line -->
  <line x1="{{ style.padding }}" y1="38" x2="{{ width - style.padding }}" y2="38" stroke="{{ theme.border }}" stroke-width="1" opacity="0.5"/>

  {% set total = technologies|sum(attribute='count') %}

  <!-- Legend items -->
  {% for tech in technologies %}
  {% set pct = (tech.count / total * 100) if total > 0 else 0 %}
  {% set item_y = 55 + loop.index0 * 22 %}
  <g transform="translate({{ style.padding }}, {{ item_y }})">
    {% set icon_data = get_icon_data_uri(tech.icon) %}
    {% if icon_data %}
    <image x="0" y="-10" width="14" height="14" href="{{ icon_data }}"/>
    {% else %}
    <circle cx="7" cy="-3" r="5" fill="{{ tech.color }}"/>
    {% endif %}
    <text x="22" y="0" class="legend-text">{{ tech.name }}</text>
    <text x="{{ width - style.padding }}" y="0" text-anchor="end" class="legend-pct">{{ "%.1f"|format(pct) }}%</text>
  </g>
  {% endfor %}
</svg>
